            "普通",
            "困难"
          ]
        },
        "楼层已交互": {
          "default": false,
          "type": "boolean"
        }
      }
    },
    "玩家": {
      "type": "object",
      "properties": {
        "LV": {
          "default": 1,
          "type": "number"
        },
        "EXP": {
          "default": 0,
          "type": "number"
        },
        "HP": {
          "default": 100,
          "type": "number"
        },
        "MaxHP": {
          "default": 100,
          "type": "number"
        },
        "MP": {
          "default": 100,
          "type": "number"
