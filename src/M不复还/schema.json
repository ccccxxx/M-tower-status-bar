        "curATK": {
          "default": 10,
          "type": "number"
        },
        "DEF": {
          "default": 10,
          "type": "number"
        },
        "curDEF": {
          "default": 10,
          "type": "number"
        },
        "G": {
          "default": 0,
          "type": "number"
